{
  "name": "puck-scarcity-radar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Structural-scarcity radar: free-data + free-LLM scanner that keeps the tech-scarcity thesis and portfolio triggers up to date.",
  "scripts": {
    "scan": "node scripts/scan.mjs",
    "scan:offline": "node scripts/scan.mjs --offline",
    "selfcheck": "node scripts/selfcheck.mjs",
    "test:unit": "node --test tests/*.test.mjs",
    "test:integration": "node --test --test-concurrency=1 tests/integration/*.test.mjs",
    "test:e2e": "node --test tests/e2e/*.test.mjs",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:e2e:browser": "playwright test",
    "screenshots": "node tests/e2e-browser/screenshots.mjs",
    "docs:word": "pandoc docs/USER-GUIDE.md -o docs/USER-GUIDE.docx --resource-path=docs",
    "docs": "npm run screenshots && npm run docs:word",
    "serve": "node scripts/serve.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  },
  "engines": {
    "node": ">=20"
  }
}
