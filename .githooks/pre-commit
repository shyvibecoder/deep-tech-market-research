#!/usr/bin/env bash
# Local-dev commit guard. Enable once:  git config core.hooksPath .githooks
# (Claude Code sessions auto-enable it via .claude/settings.json SessionStart.)
set -euo pipefail

# (1) NEVER commit bot-owned GENERATED data files from local. They are written/committed ONLY by
# the CI scanner on main; running the scanner locally (esp. --offline) rewrites them with a
# throwaway version, and `git add -A` then sweeps them in → every push collides with the bot's
# real file. Unstage AND discard any local change to them. (CI doesn't set core.hooksPath, so
# the bot is unaffected and still commits these normally.)
for f in web/data/signals.json web/data/scarcity-history.json web/data/seen.state.json \
         web/data/dca.json web/data/forecasts.json web/data/price-coverage.json; do
  if ! git diff --cached --quiet -- "$f" 2>/dev/null; then
    git restore --staged -- "$f" 2>/dev/null || true
    git checkout -- "$f" 2>/dev/null || true
    echo "pre-commit: dropped bot-owned generated file from commit -> $f"
  fi
done

# (2) Keep the User Guide in lock-step with the UI: changing web/ without touching the guide
# is a reminder (screenshots + .docx are regenerated by the `docs` workflow; the prose is on you).
staged=$(git diff --cached --name-only)
ui_changed=$(echo "$staged" | grep -E '^web/(index\.html|app\.js|options-ui\.js|styles\.css)$' || true)
guide_changed=$(echo "$staged" | grep -E '^docs/USER-GUIDE\.md$' || true)

if [ -n "$ui_changed" ] && [ -z "$guide_changed" ]; then
  echo "⚠  UI changed but docs/USER-GUIDE.md was not updated:"
  echo "$ui_changed" | sed 's/^/     /'
  echo "   → Update the guide (the docs workflow will refresh screenshots + Word)."
  echo "   → To bypass intentionally: git commit --no-verify"
  exit 1
fi
exit 0
